# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32

# MongoDB (표준 연결 문자열 권장 — Windows DNS SRV 이슈 회피)
# Atlas Connect → Drivers → 표준 연결 문자열 복사 후 사용
MONGODB_URI=mongodb://<user>:<password>@ac-xxx-shard-00-00.xxx.mongodb.net:27017,ac-xxx-shard-00-01.xxx.mongodb.net:27017,ac-xxx-shard-00-02.xxx.mongodb.net:27017/klead?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin&retryWrites=true&w=majority

# 또는 mongodb+srv (DNS가 SRV를 지원하는 환경)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/klead?appName=Cluster0

# Kakao OAuth — 2차 개발
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=

# Cloudflare R2 (Phase 1)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PREFIX=klead/          # 공유 버킷 사용 시 앱별 격리 프리픽스
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Bunny Stream (Phase 1)
# BUNNY_LIBRARY_ID=
# BUNNY_API_KEY=
# BUNNY_CDN_HOSTNAME=
